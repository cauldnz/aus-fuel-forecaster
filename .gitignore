# Data — gitignored except .gitkeep and data/static/
data/raw/*
data/interim/*
data/processed/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

# Trained models
models/*
!models/.gitkeep

# Results — keep the directory but not generated artefacts.
# (You may want to commit comparison.md once it stabilises; uncomment as needed.)
results/*
!results/.gitkeep
!results/shap/.gitkeep

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
/build/
dist/
*.egg-info/
*.egg
.eggs/
.installed.cfg

# uv / venv
.venv/
venv/
env/
.uv/
uv.lock

# Testing
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# Type checking
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# IDE / AI tooling
.idea/
.vscode/
# Claude Code scratch space — embedded git worktrees + agent state.
# Tools (ruff, mypy) also extend-exclude this in pyproject.toml.
.claude/
*.swp
*.swo
*~
.DS_Store

# OS
Thumbs.db
ehthumbs.db
Desktop.ini

# Logs
*.log
logs/
